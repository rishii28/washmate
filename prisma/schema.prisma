generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  joinDate  DateTime @default(now())
  status    String   @default("ACTIVE")
  role      String   @default("CUSTOMER")
}